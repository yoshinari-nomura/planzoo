#   | 20270113 | Fri         | 金曜日の授業 |
#   | 20270205 | Thu         | 木曜日の授業 |
#
class DeemedWeek
  attr_reader :date, :deemed_week, :summary

  def initialize(row)
    @date = Date.parse(row[:date])
    @deemed_week = row[:deemed_week]
    @summary = row[:summary]
  end

  def wday
    ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].index(@deemed_week)
  end

  def to_mhc(record_id = nil)
    lec = self
    [
      "X-SC-Subject: #{summary}",
      "X-SC-Location: ",
      "X-SC-Day: #{date.strftime("%Y%m%d")}",
      "X-SC-Time: ",
      "X-SC-Category: ",
      "X-SC-Recurrence-Tag: ",
      "X-SC-Cond: ",
      "X-SC-Duration: ",
      "X-SC-Record-Id: #{record_id || SecureRandom.uuid.upcase}",
      "X-SC-Sequence: 1",
    ].join("\n")
  end
end

