# 学年暦 (授業日程計画) 相当のカレンダ
class Calendar
  def initialize(terms, periods, deemed_weeks, holidays)
    @terms, @periods, @deemed_weeks, @holidays = terms, periods, deemed_weeks, holidays
  end

  # 学期 NTH を指定してその学期の開始日と終了日を持つ Term オブジェクトを返す
  def term(nth)
    @terms.find {|t| t.nth == nth}
  end

  # 時限 NTH を指定してその時限の開始時刻と終了時刻を持つ Period オブジェクトを返す
  def period(nth)
    @periods.find {|p| p.nth == nth}
  end

  # 曜日の読替表を返す
  def deemed_weeks
    @deemed_weeks
  end

  # 曜日の読替を考慮して DATE が何曜日なのかを返す
  def deemed_wday(date)
    (@deemed_weeks.find {|dw| dw.date == date} || date).wday
  end

  # DATE が講義日かどうかを返す
  def holiday?(date)
    @holidays.any? {|h| h.s_date <= date && date <= h.s_date + h.days - 1}
  end
end

################################################################
# Parse multiple sheets from org-file or spreadsheet.

class SheetsParser
  def self.parse(source_string)
    sheets, sheet_name, sheet_body = [], nil, []

    source_string.split("\n").each do |line|
      # skip # comment
      next if line =~ /^\s*#/

      # in table: | ... | ... |
      if line =~ /^\s*\|/
        sheet_body << line
        next
      end

      unless sheet_body.empty?
        sheets << Sheet.new(sheet_name, sheet_body.join("\n"))
        sheet_name, sheet_body = nil, []
      end

      # match: ** SheetName
      if line =~ /^[*]+ ([A-Za-z_0-9]+)/
        sheet_name = $1
      end
    end

    unless sheet_body.empty?
      sheets << Sheet.new(sheet_name, sheet_body.join("\n"))
    end
    sheets
  end
end

class Sheet
  include Enumerable

  attr_reader :name

  def initialize(sheet_name, sheet_body)
    @name, @source_string = sheet_name, sheet_body
  end

  def each
    colnames = []
    @source_string.split("\n").each do |line|
      next if line =~ /^\s*\|-/     # skip horizontal line |-
      next unless line =~ /^\s*\|/  # skip non-table line

      cols = line.sub(/^\s*\|/, '').sub(/\|\s*$/, '').split('|').map(&:strip)

      if colnames.empty?
        # take the first line as column names.
        colnames = cols
      else
        yield Sheet::Row.new(Hash[colnames.zip cols])
      end
    end
  end

  class Row
    def initialize(hash)
      @columns = hash
    end

    def [](key)
      @columns[key.to_s]
    end

  end # class Row
end # class Sheet

################################################################
### main

SPOOL_DIR = File.expand_path("~/MHC/draft")

def put_mhc_file(article, debug = false)
  record_id = SecureRandom.uuid.upcase
  if debug
    puts "---------------------------------------------------"
    puts article.to_mhc(record_id)
    puts "---------------------------------------------------"
  else
    puts "create #{SPOOL_DIR}/#{record_id}.mhc"
    File.open("#{SPOOL_DIR}/#{record_id}.mhc", "w") do |f|
      f.puts article.to_mhc(record_id)
    end
  end
end

if ARGV[0] == '--debug'
  debug = true
  ARGV.shift
end

sheets = {}

SheetsParser.parse(gets(nil)).each do |sheet|
  sheets[sheet.name] = sheet
end

terms    = sheets['Term']      .map {|row| Term.new(row)}
periods  = sheets['Period']    .map {|row| Period.new(row)}
dweeks   = sheets['DeemedWeek'].map {|row| DeemedWeek.new(row)}
holidays = sheets['Holiday']   .map {|row| Holiday.new(row)}
events   = sheets['Event']     .map {|row| Event.new(row)}
calendar = Calendar.new(terms, periods, dweeks, holidays)
lectures = sheets['Lecture'].map {|row| Lecture.new(row, calendar)}

if !debug && !File.exist?(SPOOL_DIR)
  $stderr.puts "Error: #{SPOOL_DIR} does not exist."
  exit 1
end

lectures.each do |lec|
  put_mhc_file(lec, debug)
end

calendar.deemed_weeks.each do |dw|
  put_mhc_file(dw, debug)
end

events.each do |ev|
  put_mhc_file(ev, debug)
end
