#   | 2026093221 | 情報ネットワーク論   | TCC (1)     | TCC | B3    |    3 | Mon  |        3 |        4 | 乃村 能成 | 10,11講 |
#   | 2026093221 | 情報ネットワーク論   | TCC (2)     | TCC | B3    |    3 | Thu  |        5 |        6 | 乃村 能成 | 10,11講 |
#
class Lecture
  WDAY_STRING = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']

  attr_reader :code, :subject, :abbrev, :tag, :grade, :week, :teacher,
              :room, :calendar

  def initialize(row, calendar)
    @code     = row[:code]
    @subject  = row[:subject]
    @abbrev   = row[:abbrev]
    @tag      = row[:tag]
    @grade    = row[:grade]
    @term     = row[:term].to_i
    @week     = row[:week]
    @s_period = row[:s_period].to_i
    @e_period = row[:e_period].to_i
    @teacher  = row[:teacher]
    @room     = row[:room]
    @calendar = calendar
  end

  def term;     calendar.term(@term);       end
  def s_period; calendar.period(@s_period); end
  def e_period; calendar.period(@e_period); end
  def wday;     WDAY_STRING.index(@week);   end

  def to_mhc(record_id = nil)
    lec = self
    [
      "X-SC-Subject: #{abbrev}",
      "X-SC-Location: #{room}",
      "X-SC-Day: #{exceptional_dates}",
      "X-SC-Time: #{s_period.s_time}-#{e_period.e_time}",
      "X-SC-Category: Lecture",
      "X-SC-Recurrence-Tag: #{tag}",
      "X-SC-Cond: #{week}",
      "X-SC-Duration: #{term.s_date.strftime("%Y%m%d")}-#{term.e_date.strftime("%Y%m%d")}",
      "X-SC-Record-Id: #{record_id || SecureRandom.uuid.upcase}",
      "X-SC-Sequence: 1",
      "",
      "#{code} #{subject}",
    ].join("\n")
  end

  def exceptional_dates
    lecture_wday = self.wday
    addition, deletion = [], []

    term.each_date do |date|

      if date.wday != lecture_wday &&
         calendar.deemed_wday(date) == lecture_wday
        addition << date
      end

      next unless date.wday == lecture_wday

      if calendar.deemed_wday(date) != lecture_wday || calendar.holiday?(date)
        deletion << date
      end
    end
    (addition.uniq.map {|d| d.strftime("%Y%m%d")} + deletion.uniq.map {|d| '!' + d.strftime("%Y%m%d")}).join(' ')
  end
end # class Lecture

# * Period
#   + 時限の開始時刻と終了時刻
#   + カレンダに登録されない
#   | nth | s_time | e_time |
#   |-----+--------+--------|
#   |   1 |  08:40 |  09:30 |
#   |   2 |  09:40 |  10:30 |
#   |   3 |  10:45 |  11:35 |
#   |   4 |  11:45 |  12:35 |
#   |   5 |  13:25 |  14:15 |
#   |   6 |  14:25 |  15:15 |
#   |   7 |  15:30 |  16:20 |
#   |   8 |  16:30 |  17:20 |
#   |   9 |  17:30 |  18:20 |
#   |  10 |  18:30 |  19:20 |
#
class Period
  def initialize(row)
    @columns = row
  end

  def nth
    @columns[:nth].to_i
  end

  def s_time
    @columns[:s_time]
  end

  def e_time
    @columns[:e_time]
  end
end

# * Term
#   + 各学期の Lecture を配置すべき期間 (講義開始日と終了日)
#   + カレンダに登録されない
#   + 試験期間を含めるかどうかは，試験をカレンダー上に配置したいかに依存する
#   | nth |   s_date |   e_date |
#   |-----+----------+----------|
#   |   1 | 20260408 | 20260609 |
#   |   2 | 20260610 | 20260806 |
#   |   3 | 20261001 | 20261203 |
#   |   4 | 20261204 | 20270212 |
#
class Term
  attr_reader :nth, :s_date, :e_date

  def initialize(row)
    @nth = row[:nth].to_i
    @s_date = Date.parse(row[:s_date])
    @e_date = Date.parse(row[:e_date])
  end

  def each_date
    (s_date..e_date).each do |date|
      yield date
    end
  end
end

